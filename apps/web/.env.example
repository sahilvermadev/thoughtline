# Database (scaffolding only; not required for the V1 demo critical path)
DATABASE_URL=postgresql://user:password@localhost:5432/thoughtline

# Wallet Connect (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# 0G Storage
STORAGE_ADAPTER=memory
OG_STORAGE_ENDPOINT=
OG_STORAGE_INDEXER=
OG_PRIVATE_KEY=
# Optional alias used by the 0G Compute adapter when OG_PRIVATE_KEY is unset.
PRIVATE_KEY=
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# LLM Providers
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# 0G Router. Recommended for server-side app/API-route LLM calls.
# Create the key in https://pc.0g.ai -> Dashboard -> API Keys after depositing
# funds into the Router balance.
OG_ROUTER_API_KEY=
OG_ROUTER_MODEL=deepseek/deepseek-chat-v3-0324
OG_ROUTER_BASE_URL=https://router-api.0g.ai/v1

# 0G Compute Direct. Set LLM_PROVIDER=0g-compute to use the SDK/direct path.
# Before app startup, fund the wallet, transfer funds to this provider, and
# acknowledge its signer via the 0G CLI.
OG_COMPUTE_PROVIDER_ADDRESS=
OG_COMPUTE_MODEL=

# Contract
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=16602

# Authorized runtime demo key custody.
# V1 uses this server-held RSA-OAEP keypair to unwrap agent data keys inside
# the authorized ask runtime. Production should replace this with 0G Sealed
# Inference / TEE-held key custody.
AUTHORIZED_RUNTIME_PUBLIC_KEY_JWK=
AUTHORIZED_RUNTIME_PRIVATE_KEY_JWK=
